@register_tool("get_schema", "Get the database schema with discovered node property information")
async def get_schema() -> str:
    """Get the database schema with discovered node property information."""
    schema = await fetch_schema()
    try:
        properties = await execute_cypher(
            """
            CALL db.schema.nodeTypeProperties()
            YIELD nodeLabels, propertyName, propertyTypes, mandatory
            RETURN nodeLabels, propertyName, propertyTypes, mandatory
            ORDER BY nodeLabels, propertyName
            """,
            collect=False,
        )
        schema["properties"] = properties
    except Exception as e:
        schema["properties_error"] = str(e)
    return json.dumps(schema, default=str)


@register_tool("sample_data", "Return a small sample of nodes for a discovered label")
async def sample_data(label: str, limit: int = 5) -> str:
    """Return a small sample of nodes for a discovered label."""
    if label not in ENTITY_LABELS:
        return json.dumps({"error": f"Unknown label: {label}"})

    bounded_limit = max(1, min(limit, 10))
    safe_label = label.replace("`", "``")
    query = f"MATCH (n:`{safe_label}`) RETURN n LIMIT $limit"
    try:
        result = await execute_cypher(
            query,
            {"limit": bounded_limit},
            tool_name="sample_data",
        )
        return json.dumps({"results": result}, default=str)
    except Exception as e:
        return json.dumps({"error": f"Sample query failed: {e}"})

