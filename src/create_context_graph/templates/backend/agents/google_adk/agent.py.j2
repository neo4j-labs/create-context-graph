# ---------------------------------------------------------------------------
# Message handler
# ---------------------------------------------------------------------------


_session_service = None
_runner = None
_sessions: dict[str, str] = {}  # session_id → ADK session.id


def _get_runner():
    """Lazily initialize the ADK runner and session service."""
    global _session_service, _runner
    if _runner is None:
        from google.adk.runners import Runner
        from google.adk.sessions import InMemorySessionService
        _session_service = InMemorySessionService()
        _runner = Runner(agent=agent, app_name="context-graph", session_service=_session_service)
    return _runner, _session_service


async def handle_message(message: str, session_id: str | None = None) -> dict:
    """Handle an incoming chat message."""
    session_id = resolve_session_id(session_id)

    # Store user message and retrieve context
    await store_message(session_id, "user", message)
    context = await get_context(session_id, query=message)
    history = context.get("messages", [])

    runner, session_service = _get_runner()

    # Reuse ADK session for the same session_id
    if session_id in _sessions:
        adk_session_id = _sessions[session_id]
        # ADK manages multi-turn internally — just send the current message
        input_text = message
    else:
        session = await session_service.create_session(
            app_name="context-graph", user_id=session_id
        )
        adk_session_id = session.id
        _sessions[session_id] = adk_session_id
        # New ADK session — inject any persisted history as context
        if history:
            history_block = "\n\n".join(
                f"[{m['role'].upper()}]\n{m['content']}" for m in history
            )
            input_text = (
                f"<conversation_history>\n{history_block}\n</conversation_history>\n\n"
                f"[USER]\n{message}"
            )
        else:
            input_text = message

    from google.genai import types
    content = types.Content(
        role="user", parts=[types.Part(text=input_text)]
    )

    response_text = ""
    try:
        async for event in runner.run_async(
            user_id=session_id, session_id=adk_session_id, new_message=content
        ):
            if hasattr(event, "text") and event.text:
                response_text += event.text
    except AttributeError:
        # google-genai SDK may raise AttributeError during async cleanup
        # when _async_httpx_client was never initialized
        pass

    response_text = response_text or "No response generated."
    assistant_result = await store_message(session_id, "assistant", response_text)

    return {
        "response": response_text,
        "session_id": session_id,
        "graph_data": None,
        "entities_extracted": (assistant_result or {}).get("entities", []),
        "preferences_detected": (assistant_result or {}).get("preferences", []),
    }


async def handle_message_stream(message: str, session_id: str | None = None) -> None:
    """Handle a chat message with streaming text deltas via the collector event queue."""
    session_id = resolve_session_id(session_id)

    collector = get_collector()
    await store_message(session_id, "user", message)
    context = await get_context(session_id, query=message)
    history = context.get("messages", [])

    runner, session_service = _get_runner()

    # Reuse ADK session for the same session_id
    if session_id in _sessions:
        adk_session_id = _sessions[session_id]
        input_text = message
    else:
        session = await session_service.create_session(
            app_name="context-graph", user_id=session_id
        )
        adk_session_id = session.id
        _sessions[session_id] = adk_session_id
        if history:
            history_block = "\n\n".join(
                f"[{m['role'].upper()}]\n{m['content']}" for m in history
            )
            input_text = (
                f"<conversation_history>\n{history_block}\n</conversation_history>\n\n"
                f"[USER]\n{message}"
            )
        else:
            input_text = message

    from google.genai import types
    content = types.Content(
        role="user", parts=[types.Part(text=input_text)]
    )

    response_text = ""
    try:
        async for event in runner.run_async(
            user_id=session_id, session_id=adk_session_id, new_message=content
        ):
            if hasattr(event, "text") and event.text:
                collector.emit_text_delta(event.text)
                response_text += event.text
    except AttributeError:
        # google-genai SDK may raise AttributeError during async cleanup
        pass

    response_text = response_text or "No response generated."
    assistant_result = await store_message(session_id, "assistant", response_text)
    if assistant_result:
        collector.emit_entities_extracted(assistant_result.get("entities", []))
        collector.emit_preferences_detected(assistant_result.get("preferences", []))
    collector.emit_done(response_text, session_id)
