_main_loop: asyncio.AbstractEventLoop | None = None


def _run_sync(coro):
    """Run an async coroutine from a synchronous context.

    When called from the event loop's thread (ADK's sync tool callbacks inside
    run_async), uses nest_asyncio-patched ``run_until_complete``.
    When called from a worker thread, uses ``run_coroutine_threadsafe`` to
    schedule on the main loop.
    Falls back to ``asyncio.run()`` when no event loop is available.
    """
    try:
        loop = asyncio.get_running_loop()
    except RuntimeError:
        # No event loop — use the captured main loop if available, else new loop
        loop = _main_loop
        if loop is not None and loop.is_running():
            future = asyncio.run_coroutine_threadsafe(coro, loop)
            return future.result(timeout=30)
        return asyncio.run(coro)

    # Same thread as the event loop: reentrant call via nest_asyncio
    loop_thread = getattr(loop, "_thread_id", None)
    current_tid = threading.current_thread().ident
    if loop_thread is None or current_tid == loop_thread:
        return loop.run_until_complete(coro)

    # Different thread: schedule on the loop safely
    future = asyncio.run_coroutine_threadsafe(coro, loop)
    return future.result(timeout=30)


